<?xml version="1.0" encoding="utf-8"?>
<!-- ================================================ -->
<!-- 화면 2: 위험 알림 화면 (activity_hazard.xml)     -->
<!-- HA-002 퀵 액션 버튼 + HA-005 커스텀 지도 추가   -->
<!-- ================================================ -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:contentInsetStart="24dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_warning"
                app:tint="#0059BA" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="위험 알림"
                android:textColor="#0059BA"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- 펄스 점 (애니메이션은 Activity에서 처리) -->
            <View
                android:id="@+id/pulseDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_circle_red" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="8dp"
                android:text="실시간 분석"
                android:textColor="#BA1A1A"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />

            <!-- HA-002: TTS 토글 버튼 -->
            <ImageButton
                android:id="@+id/btnTtsToggle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_chip_blue"
                android:contentDescription="음성 안내 토글"
                android:src="@drawable/ic_volume_on"
                app:tint="#0059BA"
                android:padding="8dp"
                android:layout_marginEnd="4dp" />

            <!-- HA-002: 햅틱 토글 버튼 -->
            <ImageButton
                android:id="@+id/btnHapticToggle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_chip_blue"
                android:contentDescription="진동 피드백 토글"
                android:src="@drawable/ic_vibration_on"
                app:tint="#0059BA"
                android:padding="8dp"
                android:layout_marginEnd="16dp" />

        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 상태 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_rounded_blue_container"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GPS 활성화 및 스캔 중"
                    android:textColor="#CCFEFCFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="3개의 위험 요소 탐지됨"
                    android:textColor="#FEFCFF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>

            <!-- 환경 스캔 타이틀 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="환경 스캔"
                android:textColor="#191C1D"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- HA-003: 위험 카드 1 - 즉시 대응 (빨간) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_hazard_card_red"
                android:orientation="horizontal">

                <View
                    android:layout_width="6dp"
                    android:layout_height="match_parent"
                    android:background="#BA1A1A" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:background="@drawable/bg_badge_red"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="즉시 대응"
                        android:textColor="#93000A"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="열려 있는 맨홀"
                        android:textColor="#191C1D"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="경로상에 있습니다. 멈춰서 왼쪽으로 우회하세요."
                        android:textColor="#414754"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- HA-003: 위험 카드 2 - 가까움 (주황) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_hazard_card"
                android:orientation="horizontal">

                <View
                    android:layout_width="6dp"
                    android:layout_height="match_parent"
                    android:background="#9A4100" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:background="@drawable/bg_badge_orange"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="가까움"
                        android:textColor="#341100"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="빠른 자전거"
                        android:textColor="#191C1D"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="2시 방향에서 접근 중. 빠르게 이동 중."
                        android:textColor="#414754"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- HA-003: 위험 카드 3 - 전방 (파란) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_hazard_card"
                android:orientation="horizontal">

                <View
                    android:layout_width="6dp"
                    android:layout_height="match_parent"
                    android:background="#0059BA" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:background="@drawable/bg_badge_blue"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="전방"
                        android:textColor="#001F29"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="계단 아래"
                        android:textColor="#191C1D"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="앞에 지하철 입구. 점자 블록 있음."
                        android:textColor="#414754"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- HA-005: 주변 위험 지도 섹션 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="주변 위험 지도"
                    android:textColor="#191C1D"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- 확대 버튼 -->
                <ImageButton
                    android:id="@+id/btnExpandMap"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_chip_blue"
                    android:src="@drawable/ic_fullscreen"
                    app:tint="#0059BA"
                    android:padding="6dp"
                    android:contentDescription="지도 전체화면" />
            </LinearLayout>

            <!-- HA-005: 커스텀 2D 지도 뷰 -->
            <com.example.luminance.ui.hazard.CustomMapView
                android:id="@+id/customMapView"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 하단 네비게이션 -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>